# Server
PORT=3000

# Database (required for DATA_LAYER=live)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
JWT_SECRET=change-me-in-production

# AI Engine (platform-level keys, also used as fallback)
GROQ_API_KEY=your-groq-api-key
MISTRAL_API_KEY=your-mistral-api-key

# BYOK credential encryption (required for LLM key storage)
CREDENTIAL_ENCRYPTION_KEY=change-me-in-production

# Data layer: "fake" for local dev without Supabase, "live" for real database
DATA_LAYER=fake

# Scheduler tuning (optional)
DEBOUNCE_MS=3000
ROUND_COOLDOWN_MS=5000
MAX_RETRIES=3
